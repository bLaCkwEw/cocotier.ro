---
import Nav from "@lib/Nav.astro";
import Footer from "@lib/Footer.astro";
import SkipLink from "@lib/design-system/components/SkipLink.astro";
import AdNote from "@lib/AdNote.astro";
import { SEO } from "astro-seo";

const {
  title,
  description,
  image,
  type = "website",
  noindex = false,
  article,
} = Astro.props;

const ogRoute = Astro.url.pathname.replace(/^\/|\/$/g, "") || "home";
const ogImage = image ?? `/open-graph/${ogRoute}.png`;

const openGraph = {
  basic: {
    title: title || "cocotier.ro",
    type: type,
    image: new URL(ogImage, Astro.url.origin).href,
    url: Astro.url.toString(),
  },
  optional: {
    siteName: "cocotier.ro",
    locale: "en_US",
    ...(description ? { description } : {}),
  },
  image: {
    alt: title || description || "cocotier.ro",
  },
  ...(article ? { article } : {}),
};

const twitterCard = {
  card: "summary_large_image" as const,
  image: new URL(ogImage, Astro.url.origin).href,
  imageAlt: title || description || "cocotier.ro",
};

const extendMeta = [
  { name: "author", content: "bLaCkwEw" },
  { name: "generator", content: Astro.generator },
];
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<SEO
			title={title}
			titleTemplate="%s - cocotier.ro"
			titleDefault="cocotier.ro"
			description={description}
			canonical={Astro.url.toString()}
			noindex={noindex}
			openGraph={openGraph}
			twitter={twitterCard}
			extend={{
				link: [
					{ rel: "icon", href: "/favicon.png" },
				],
				meta: extendMeta,
			}}
		/>

		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Theme toggle -->
		<script is:inline>
			if (
				localStorage.theme === "dark" ||
				(!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>
	<body
		class="mx-2 max-w-2xl bg-stone-50 text-zinc-900 dark:bg-zinc-900 dark:text-stone-50 md:mx-auto"
	>
		<SkipLink href="#main-content" />
		<Nav />
		<slot />
		<Footer />
		<AdNote />
	</body>
</html>

---
import { Icon } from "astro-icon/components";
import Button from "@lib/design-system/components/Button.astro";
---

<Button id="theme-toggle" aria-label="Theme Toggle">
	<Icon name="tabler:sun-filled" size={24} class="hidden dark:block" />
	<Icon name="tabler:moon-filled" size={24} class="block dark:hidden" />
</Button>

<script is:inline>
	document.getElementById("theme-toggle")?.addEventListener("click", () => {
		if (document.documentElement.classList.contains("dark")) {
			localStorage.theme = "light";
			document.documentElement.classList.remove("dark");
		} else {
			localStorage.theme = "dark";
			document.documentElement.classList.add("dark");
		}
	});
</script>
---
import { Icon } from "astro-icon/components";
---

<button
	id="theme-toggle"
	class="flex rounded transition hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
	aria-label="Theme Toggle"
>
	<Icon name="tabler:sun-filled" size={24} class="hidden dark:block" />
	<Icon name="tabler:moon-filled" size={24} class="block dark:hidden" />
</button>

<script is:inline>
	document.getElementById("theme-toggle")?.addEventListener("click", () => {
		if (document.documentElement.classList.contains("dark")) {
			localStorage.theme = "light";
			document.documentElement.classList.remove("dark");
		} else {
			localStorage.theme = "dark";
			document.documentElement.classList.add("dark");
		}
	});
</script>

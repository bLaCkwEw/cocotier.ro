---
import ThemeToggle from "@lib/ThemeToggle.astro";
import FocusLink from "@lib/design-system/components/FocusLink.astro";

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isNow = currentPath === "/now" || currentPath.startsWith("/now/");
const isBlog = currentPath === "/blog" || currentPath.startsWith("/blog/");
---

<nav class="my-2 flex justify-between border-b-2 border-accent py-2">
	<FocusLink href="/" class="flex" aria-current={isHome ? "page" : undefined}>
		<img src="/favicon.png" alt="Favicon" title="Pixel Art Coconut Tree" width="32" height="32" />
	</FocusLink>
	<div class="flex items-center gap-4">
		<FocusLink href="/now" aria-current={isNow ? "page" : undefined}>Now</FocusLink>
		<FocusLink href="/blog" aria-current={isBlog ? "page" : undefined}>Archive</FocusLink>
		<ThemeToggle />
	</div>
</nav>
---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
	href={href}
	class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:bg-stone-50 focus:px-4 focus:py-2 focus:text-zinc-900 focus:shadow-[2px_2px_0px_0px] focus:shadow-black dark:focus:bg-zinc-900 dark:focus:text-stone-50 dark:focus:shadow-stone-300"
>
	Skip to main content
</a>